generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Match {
  id        String   @id @default(cuid())
  round     Int?              // Para fase de grupos: 1-3. Para eliminatórias: null
  matchNum  Int               // Número do jogo dentro da rodada/fase
  phase     String   @default("groups")  // "groups", "segunda_fase", "oitavas", "quartas", "semifinal", "terceiro_lugar", "final"
  homeTeam  String
  awayTeam  String
  homeName  String
  awayName  String
  bets      Bet[]
  createdAt DateTime @default(now())

  @@index([round])
  @@index([round, matchNum])
  @@index([phase])
  @@index([phase, matchNum])
}

model Player {
  id        String   @id @default(cuid())
  name      String   @unique
  token     String   @unique
  bets      Bet[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([name])
}

model Bet {
  id             String   @id @default(cuid())
  playerId       String
  matchId        String
  homeScore      Int?
  awayScore      Int?
  penaltyWinner  String?  // "home" or "away" — only for knockout phases when scores are tied
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([playerId, matchId])
  @@index([playerId])
  @@index([matchId])
}

model PhaseWinner {
  id         String   @id @default(cuid())
  phase      String   @unique  // "groups", "segunda_fase", "oitavas", "quartas", "semifinal", "terceiro_lugar", "final", "segundo_lugar", "terceiro_lugar_geral"
  winnerName String
  audioSrc   String?  // Path to audio file, e.g. "/win/champion.mp3". Null = use default winner.mp3
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
